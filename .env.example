# REQUIRED for mobile wallet connections from a normal phone browser (Safari/Chrome).
# Free, 1 minute: sign in at https://cloud.reown.com (formerly cloud.walletconnect.com),
# create a project, copy the Project ID here. In-app wallet browsers (MetaMask/Trust)
# work without it, but regular mobile browsers need it for deep-linking.
VITE_WALLETCONNECT_PROJECT_ID=get_from_cloud.reown.com
VITE_AIRDROP_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VITE_SITE_URL=https://shibshib.xyz
VITE_USE_TESTNET=false
